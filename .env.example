# Postgres do seu EasyPanel (a mesma instância que já roda n8n/Evolution API)
DATABASE_URL=postgresql://usuario:senha@host:5432/rodei

# Se o Postgres do EasyPanel usar SSL self-signed e a conexão falhar, deixe "true" (default).
# Se for conexão local sem SSL, mude para "false".
DATABASE_SSL=true

# Segredo compartilhado entre o workflow do n8n e esta aplicação.
# Gere um valor aleatório forte, ex: openssl rand -hex 32
INTERNAL_API_SECRET=troque-por-um-valor-aleatorio-forte

# Mercado Pago (assinaturas)
MERCADOPAGO_ACCESS_TOKEN=
